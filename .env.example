# Example local development values
# Shared
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://redis:6379/0
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=job_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@host.docker.internal:5432/job_bot

# Service URLs
API_GATEWAY_PORT=8000
JOB_SERVICE_PORT=8001
SCRAPER_SERVICE_PORT=8002
ORCHESTRATOR_SERVICE_PORT=8003
WORKER_SERVICE_PORT=8004
AI_SERVICE_PORT=8005
APPLY_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
WEB_PORT=3000

JOB_SERVICE_URL=http://job-service:8001
SCRAPER_SERVICE_URL=http://scraper-service:8002
ORCHESTRATOR_SERVICE_URL=http://orchestrator-service:8003
WORKER_SERVICE_URL=http://worker-service:8004
AI_SERVICE_URL=http://ai-service:8005
APPLY_SERVICE_URL=http://apply-service:8006
NOTIFICATION_SERVICE_URL=http://notification-service:8007

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5

# Storage
DOCUMENT_STORAGE_PATH=/data/documents

# Scraping
SCRAPE_REQUEST_TIMEOUT_SECONDS=30
SCRAPE_MAX_RETRIES=3
SCRAPE_THROTTLE_SECONDS=1.0

# Workers
WORKER_CONCURRENCY=4
